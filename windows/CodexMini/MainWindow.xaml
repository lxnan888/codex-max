<Window x:Class="CodexMiniWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Max"
        Width="760"
        Height="680"
        MinWidth="680"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#0D1017">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171C27"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111722"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2E3A4C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#92A0B5"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#D4DCEA"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#6AE6FF"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#6DFA9A"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FFC06E"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#C99AFF"/>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#334055"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="52"/>
            <Setter Property="MinWidth" Value="190"/>
            <Setter Property="Background" Value="#163B2A"/>
            <Setter Property="BorderBrush" Value="#2D8050"/>
            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#202A3A"/>
            <Setter Property="BorderBrush" Value="#4B5B72"/>
            <Setter Property="Foreground" Value="{StaticResource SoftBrush}"/>
        </Style>

        <Style x:Key="WorkspaceComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#F2F6FF"/>
            <Setter Property="Background" Value="#151D2B"/>
            <Setter Property="BorderBrush" Value="#55708F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <Grid>
                                                <ContentPresenter Margin="12,0,36,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <TextBlock Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#B8C8DD"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,13,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="260"
                                        Background="#111722"
                                        BorderBrush="#55708F"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F2F6FF"/>
                        <Setter Property="Background" Value="#111722"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="7"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#26374D"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1D4B35"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="#182131"/>
            <Setter Property="BorderBrush" Value="#40506A"/>
            <Setter Property="Foreground" Value="{StaticResource SoftBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1017" Offset="0"/>
                <GradientStop Color="#151B27" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE8EA;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="32"
                       Foreground="{StaticResource CyanBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Codex Max"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="VSCode Codex 本地控制器"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#9BA8BB"/>
            </StackPanel>
            <Border Grid.Column="2"
                    Height="34"
                    MinWidth="112"
                    Padding="12,0"
                    CornerRadius="17"
                    Background="#183F2D"
                    BorderBrush="#2C6B47"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StateDot" Text="●" Foreground="{StaticResource GreenBrush}" FontSize="12" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StateText" Text="未启动" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="控制" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="HttpValue" Text="-" Foreground="{StaticResource GreenBrush}" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                            <TextBlock x:Name="HttpFootnote" Text="-" Foreground="#8290A4" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}" Margin="8,0,0,8">
                        <StackPanel>
                            <TextBlock Text="端口" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="PortValue" Text="8787" Foreground="{StaticResource CyanBrush}" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                            <TextBlock Text="127.0.0.1 本地服务" Foreground="#8290A4" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,8,8,0">
                        <StackPanel>
                            <TextBlock Text="会话来源" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="ThreadValue" Text="GUI" Foreground="{StaticResource PurpleBrush}" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                            <TextBlock x:Name="ThreadFootnote" Text="从 VSCode Codex WebView 实时读取" Foreground="#8290A4" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}" Margin="8,8,0,0">
                        <StackPanel>
                            <TextBlock Text="更新" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="UpdatedAt" Text="-" Foreground="{StaticResource OrangeBrush}" FontSize="18" FontWeight="Bold" Margin="0,9,0,0"/>
                            <TextBlock Text="启动器只在点击启动时拉起 VSCode" Foreground="#8290A4" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="当前工作区" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="已默认选中第一个可用工作区，可直接启动 VSCode" Foreground="#8D9AAF" FontSize="11"/>
                            </StackPanel>
                            <Button x:Name="BrowseWorkspaceButton"
                                    Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="118"
                                    Background="#26374D"
                                    BorderBrush="#6686AE"
                                    Foreground="#F2F6FF"
                                    Margin="12,0,0,0"
                                    Click="BrowseWorkspace_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="选择目录" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <StackPanel Grid.Row="1" Margin="0,14,0,0">
                            <ComboBox x:Name="WorkspaceCombo"
                                      Style="{StaticResource WorkspaceComboStyle}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectionChanged="WorkspaceCombo_SelectionChanged"
                                      ToolTip="选择启动 VSCode 时要打开的工作区"/>
                            <Border Margin="0,10,0,0"
                                Padding="12"
                                CornerRadius="12"
                                Background="#0F1520"
                                BorderBrush="#374A63"
                                BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="WorkspaceKindText"
                                               Text="工作区"
                                               Foreground="{StaticResource CyanBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="WorkspaceTitleText"
                                               Text="正在读取 VSCode 最近工作区..."
                                               Foreground="#F2F6FF"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="WorkspaceValueText"
                                               Text=""
                                               Foreground="#93A4B8"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="操作" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button x:Name="LaunchCdpButton" Style="{StaticResource PrimaryButtonStyle}" Click="LaunchCdp_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="LaunchCdpIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="LaunchCdpText" Text="启动 VSCode" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="OpenWebButton" Style="{StaticResource SecondaryButtonStyle}" Background="#1A3E62" BorderBrush="#3C79B9" Foreground="#8EC2FF" Click="OpenWeb_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="打开网页" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CopyLinkButton" Style="{StaticResource SecondaryButtonStyle}" Background="#123F49" BorderBrush="#3290A0" Foreground="{StaticResource CyanBrush}" Click="CopyLink_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="复制链接" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RestartButton" Style="{StaticResource SecondaryButtonStyle}" Background="#4B321C" BorderBrush="#986946" Foreground="{StaticResource OrangeBrush}" Click="Restart_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="重启服务" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RefreshButton" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="刷新状态" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LogPreview"
                           Grid.Column="0"
                           Foreground="#9BA8BA"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button x:Name="OpenLogsButton"
                        Grid.Column="1"
                        Style="{StaticResource LinkButtonStyle}"
                        Content="&#xE8A5; 打开日志"
                        Click="OpenLogs_Click"/>
                <TextBlock x:Name="InstallPath"
                           Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,8,0,0"
                           VerticalAlignment="Center"
                           Foreground="#788496"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
