<Window x:Class="CodexMiniWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Max"
        Width="940"
        Height="470"
        MinWidth="900"
        MinHeight="470"
        WindowStartupLocation="CenterScreen"
        Background="#10121A">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1D212C"/>
        <SolidColorBrush x:Key="CardBrush" Color="#161922"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#323D4E"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8996A8"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#B6C1D2"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#53DEF7"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#5CEE8E"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FFB263"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#B980FF"/>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#283242"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,4,10,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource SoftBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#414B5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F1117" Offset="0"/>
                <GradientStop Color="#1A1D28" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="66"/>
                <RowDefinition Height="136"/>
                <RowDefinition Height="118"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE8EA;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="34"
                           Foreground="{StaticResource CyanBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Codex Max"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="本地部署版 · 手机连接这台 Windows 上的 Codex"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#8F9CB0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Border Grid.Column="2"
                        Height="34"
                        MinWidth="126"
                        Padding="12,0"
                        CornerRadius="17"
                        Background="#173F2C"
                        BorderBrush="#285A40"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="StateDot" Text="●" Foreground="{StaticResource GreenBrush}" FontSize="12" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StateText" Text="运行中" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="HTTP" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="HttpValue" Text="-" Foreground="{StaticResource GreenBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock x:Name="HttpFootnote" Text="-" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="端口" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="PortValue" Text="8787" Foreground="{StaticResource CyanBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock x:Name="PortFootnote" Text="本机入口" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="线程" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="ThreadValue" Text="-" Foreground="{StaticResource PurpleBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock x:Name="ThreadFootnote" Text="尚未读取线程" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="InstallPath"
                               Grid.Row="1"
                               VerticalAlignment="Center"
                               Foreground="#788496"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="常用操作" Foreground="White" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="本机服务、局域网访问和本地日志" Foreground="#707C8F" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="UpdatedAt" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#808C9E" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OpenWebButton" Grid.Column="0" Style="{StaticResource ActionButtonStyle}" Background="#1A3E62" BorderBrush="#315E91" Foreground="#64A5FF" Click="OpenWeb_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="打开网页" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CopyLinkButton" Grid.Column="1" Style="{StaticResource ActionButtonStyle}" Background="#133E48" BorderBrush="#2C7380" Foreground="{StaticResource CyanBrush}" Click="CopyLink_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="复制链接" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="RestartButton" Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Background="#4B321C" BorderBrush="#805735" Foreground="{StaticResource OrangeBrush}" Click="Restart_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="重启服务" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="RefreshButton" Grid.Column="3" Style="{StaticResource ActionButtonStyle}" Background="#222A38" BorderBrush="#4A5668" Foreground="{StaticResource SoftBrush}" Margin="0,4,0,0" Click="Refresh_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="刷新状态" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42*"/>
                    <ColumnDefinition Width="39*"/>
                    <ColumnDefinition Width="104"/>
                    <ColumnDefinition Width="92"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LogPreview"
                           Foreground="#768294"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="8,0,12,0">
                    <TextBlock x:Name="EntryKind" Foreground="#5C6778" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="EntryUrl" Foreground="#8793A6" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" Width="330" TextAlignment="Right"/>
                </StackPanel>
                <Button x:Name="OpenLogsButton" Grid.Column="2" Style="{StaticResource LinkButtonStyle}" Content="&#xE8A5; 打开日志" Click="OpenLogs_Click"/>
                <Button x:Name="StartStopButton" Grid.Column="3" Style="{StaticResource LinkButtonStyle}" Content="停止" Click="StartStop_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
